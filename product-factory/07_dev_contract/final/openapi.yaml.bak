  /api/verify:
    post:
      tags: [account]
      summary: 通用敏感动作二次验证
      x-function-id: F-1038
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              additionalProperties: true
              description: 验证凭据（密码 / TOTP / passkey assertion）
      responses:
        '200':
          description: 验证通过，放行受保护动作
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
        '403':
          $ref: '#/components/responses/ForbiddenError'
  /api/user/self/aff_transfer:
    post:
      tags: [account]
      summary: 邀请额度划转为可用额度
      x-function-id: F-1044
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                quota:
                  type: integer
                  description: 划转额度，>= QuotaPerUnit
              required: [quota]
      responses:
        '200':
          description: 划转成功
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
        '400':
          $ref: '#/components/responses/BadRequestError'

  # ==================== 模块二：令牌管理 ====================
  /api/token/:
    get:
      tags: [token]
      summary: 令牌列表（分页，key 脱敏）
      x-function-id: F-3002
      security:
        - sessionAuth: []
      parameters:
        - $ref: '#/components/parameters/PageParam'
        - $ref: '#/components/parameters/PageSizeParam'
      responses:
        '200':
          description: 令牌列表（UserView，key 脱敏）
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        allOf:
                          - $ref: '#/components/schemas/Pagination'
                          - type: object
                            properties:
                              items:
                                type: array
                                items:
                                  $ref: '#/components/schemas/TokenUserView'
    post:
      tags: [token]
      summary: 创建令牌
      x-function-id: F-3001
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenCreateRequest'
      responses:
        '200':
          description: 创建后令牌（UserView，key 脱敏）
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        $ref: '#/components/schemas/TokenUserView'
        '400':
          $ref: '#/components/responses/BadRequestError'
    put:
      tags: [token]
      summary: 更新令牌（含 status_only）
      x-function-id: F-3006
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              allOf:
                - $ref: '#/components/schemas/TokenCreateRequest'
                - type: object
                  properties:
                    id:
                      type: integer
                    status_only:
                      type: boolean
                  required:
                    - id
      responses:
        '200':
          description: 更新后令牌（UserView）
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        $ref: '#/components/schemas/TokenUserView'
        '400':
          $ref: '#/components/responses/BadRequestError'
  /api/token/{id}:
    delete:
      tags: [token]
      summary: 删除单个令牌
      x-function-id: F-3007
      security:
        - sessionAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        '200':
          description: 删除成功（软删）
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SuccessResponse'
  /api/token/batch:
    post:
      tags: [token]
      summary: 批量删除令牌
      x-function-id: F-3007
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                ids:
                  type: array
                  items:
                    type: integer
              required: [ids]
      responses:
        '200':
          description: 删除数量
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        type: integer
  /api/token/search:
    get:
      tags: [token]
      summary: 令牌关键词/前缀搜索
      x-function-id: F-3003
      security:
        - sessionAuth: []
      parameters:
        - $ref: '#/components/parameters/KeywordParam'
        - $ref: '#/components/parameters/PageParam'
        - $ref: '#/components/parameters/PageSizeParam'
      responses:
        '200':
          description: 搜索结果（UserView，key 脱敏）
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        allOf:
                          - $ref: '#/components/schemas/Pagination'
                          - type: object
                            properties:
                              items:
                                type: array
                                items:
                                  $ref: '#/components/schemas/TokenUserView'
  /api/token/{id}/key:
    post:
      tags: [token]
      summary: 获取单个令牌明文 key（受控）
      x-function-id: F-3004
      security:
        - sessionAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        '200':
          description: 完整明文 key
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        type: string
  /api/token/keys/batch:
    post:
      tags: [token]
      summary: 批量获取明文 key（上限 100）
      x-function-id: F-3005
      security:
        - sessionAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                ids:
                  type: array
                  maxItems: 100
                  items:
                    type: integer
              required: [ids]
      responses:
        '200':
          description: id→key 映射（仅本人令牌）
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        type: object
                        additionalProperties:
                          type: string
        '400':
          $ref: '#/components/responses/BadRequestError'
  /api/usage/token:
    get:
      tags: [token]
      summary: 令牌用量查询（credit_summary，OpenAI 兼容）
      x-function-id: F-3012
      security:
        - tokenReadAuth: []
      responses:
        '200':
          description: 用量摘要
          content:
            application/json:
              schema:
                allOf:
                  - $ref: '#/components/schemas/ApiResponse'
                  - type: object
                    properties:
                      data:
                        $ref: '#/components/schemas/UsageCreditSummary'
        '401':
          $ref: '#/components/responses/UnauthorizedError'

