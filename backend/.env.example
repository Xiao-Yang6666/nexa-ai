# Nexa 后端环境变量模板 — 复制为 .env 并填入真实值（.env 不进 git）
# 启动前 export 这些变量，或用 dotenv 加载。

# --- 数据库 ---
DB_URL=jdbc:postgresql://localhost:5432/nexa
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# --- JWT 签发密钥（>= 32 字节，HS256；生产用强随机值）---
JWT_SECRET=replace-with-strong-random-secret-at-least-32-bytes
JWT_TTL_SECONDS=604800

# --- 敏感字段 AES-256 加密主密钥（Base64 编码的 32 字节）---
# 生成示例： openssl rand -base64 32
SECURITY_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# --- CORS 允许的前端 origin（逗号分隔，须含真实前端地址）---
APP_CORS_ALLOWED_ORIGINS=http://localhost:3100

# --- 端口 ---
SERVER_PORT=8080
